# ===========================================
# Tarife Attar Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values

# ---------------------------------------------
# Sanity CMS
# ---------------------------------------------
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Read token (for fetching content)
SANITY_API_TOKEN=

# Write token (for mutations - admin only)
SANITY_API_WRITE_TOKEN=

# Webhook secret for cache revalidation (REQUIRED for security)
SANITY_REVALIDATE_SECRET=

# ---------------------------------------------
# AI Services
# ---------------------------------------------
# OpenAI (for chat/curator features)
OPENAI_API_KEY=

# Anthropic Claude (for content generation)
ANTHROPIC_API_KEY=

# ---------------------------------------------
# Shopify
# ---------------------------------------------
# Admin API (server-side only)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_API_ACCESS_TOKEN=

# Storefront API (client-side safe)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# ---------------------------------------------
# Etsy (Optional)
# ---------------------------------------------
ETSY_API_KEY=
ETSY_ACCESS_TOKEN=
ETSY_REFRESH_TOKEN=
ETSY_SHOP_ID=

# ---------------------------------------------
# Security Notes
# ---------------------------------------------
# - Never commit .env.local to git
# - Rotate tokens regularly
# - Use different keys for dev/staging/production
# - SANITY_REVALIDATE_SECRET must be set in production
